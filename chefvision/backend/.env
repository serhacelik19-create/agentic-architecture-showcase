DATABASE_URL=postgresql://YOUR_DATABASE_USER:YOUR_DATABASE_PASSWORD@YOUR_DATABASE_HOST/YOUR_DATABASE_NAME?sslmode=require
REDIS_URL=rediss://default:YOUR_REDIS_PASSWORD@YOUR_REDIS_HOST:6379/0
JWT_SECRET_KEY=YOUR_JWT_SECRET_KEY_HERE
DEBUG=True

# AI Models
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
GEMINI_FLASH_MODEL=gemini-3.1-flash-lite-preview
GEMINI_VISION_MODEL=gemini-3-flash-preview

# Firebase
FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY_HERE

# App Store Connect
APPLE_SHARED_SECRET=YOUR_APPLE_SHARED_SECRET_HERE
APPLE_KEY_ID=YOUR_APPLE_KEY_ID_HERE
APPLE_ISSUER_ID=YOUR_APPLE_ISSUER_ID_HERE
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_CONTENT_HERE\n-----END PRIVATE KEY-----"
APPLE_BUNDLE_ID=com.chefvision

# Environment
IS_PRODUCTION=False
ALLOW_TEST_PURCHASE_BYPASS=True
